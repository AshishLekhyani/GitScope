# GitScope Neural AI Engine — Environment Variables
# Copy to .env and fill in values

# ── Networking ──────────────────────────────────────────────────────────────
PORT=8765
NEXTJS_ORIGIN=http://localhost:3000

# ── GitHub (for autonomous learning — optional but recommended) ─────────────
# Personal access token: github.com/settings/tokens (read:public_repo scope)
# With a token: 5,000 req/hr. Without: 60 req/hr (crawling is much slower)
GITHUB_TOKEN=

# ── Autonomous Learning ─────────────────────────────────────────────────────
# Set to "1" to enable background learning from GitHub + OWASP docs
# Learning runs every 6h (GitHub) and 24h (docs)
# The knowledge base lives in Neon PostgreSQL (DATABASE_URL) — persists forever
GITSCOPE_AUTO_LEARN=0

# ── Intervals (seconds) ─────────────────────────────────────────────────────
GITHUB_LEARN_INTERVAL=21600   # 6 hours
DOC_CRAWL_INTERVAL=86400      # 24 hours

# ── Anthropic (optional enhancement) ───────────────────────────────────────
# If set, Anthropic is used to enhance the neural engine's summaries
ANTHROPIC_API_KEY=

# ── Database (Neon PostgreSQL + pgvector) ───────────────────────────────────
# Required for persistent AI memory. Add to Render as a secret env var.
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
