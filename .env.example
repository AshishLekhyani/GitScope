# Database
DATABASE_URL=

# NextAuth
# Required: generate with `openssl rand -base64 32`
NEXTAUTH_SECRET=
# Required in production: your Vercel URL (no trailing slash)
# Example: https://your-app.vercel.app
NEXTAUTH_URL=

# GitHub OAuth
GITHUB_ID=
GITHUB_SECRET=

# Shared GitHub API token (optional)
# Classic PAT with public_repo scope. Raises unauthenticated rate limit from 60 -> 5000 req/hr.
GITHUB_TOKEN=
# Optional: when true, endpoints may use GITHUB_TOKEN as a shared fallback.
# Keep false to avoid burning a single owner token across all users.
GITHUB_SHARED_FALLBACK=false

# Personal token encryption key (required for storing user PATs)
# Generate with: openssl rand -base64 32
GITHUB_PAT_ENCRYPTION_KEY=

# BYOK key encryption secret (REQUIRED in production — encrypts user AI API keys at rest)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_SECRET=

# CSRF Protection (uses NEXTAUTH_SECRET as fallback if not set)
# Generate with: openssl rand -base64 32
CSRF_SECRET=

# Request Signing for Webhooks (uses NEXTAUTH_SECRET as fallback)
# Generate with: openssl rand -base64 32
REQUEST_SIGNING_SECRET=

# Email (SMTP) - Required for email verification and password reset
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM=GitScope <your_email@gmail.com>

# ── FREE AI Providers (no credit card, sign up and get a key) ─────────────────
# Recommended: set at least GROQ_API_KEY + GEMINI_API_KEY for solid free coverage.
# These are used as shared fallback keys for all users who have no BYOK key set.

# Groq — best free tier (500 req/day on Llama 3.3 70B, 14k req/day on 8B)
# Sign up free: https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini — very generous free tier (1,500 req/day on Flash)
# Sign up free: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Cerebras — fast free inference (Llama 3.1 70B)
# Sign up free: https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# HuggingFace — open-source models (Mistral 7B, Llama 8B, Phi-3.5-mini)
# Without a key: anonymous, ~30 req/day per IP. With key: ~1000+ req/day.
# Sign up free: https://huggingface.co/settings/tokens
HF_API_KEY=

# DeepSeek — very cheap ($0.14/1M tokens), almost free for low usage
# Sign up: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Mistral AI — free tier available (la Plateforme)
# Sign up: https://console.mistral.ai
MISTRAL_API_KEY=

# ── PAID AI Providers (optional — used as shared server keys for all users) ──────
# Users can always bring their own paid keys via BYOK in Settings.

# Anthropic Claude: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# OpenAI GPT: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional per-user AI tier overrides
# Format: email:plan,email2:plan  where plan is free|developer
AI_TIER_OVERRIDES=
# Comma-separated email domains auto-upgraded to Developer plan
AI_DEVELOPER_DOMAINS=
# Comma-separated admin emails (access /admin panel, set user tiers)
AI_TIER_ADMIN_EMAILS=

# AI job cron worker (used by /api/internal/ai-jobs/cron)
# If set, requests must include Authorization: Bearer <secret>
AI_JOBS_CRON_SECRET=
# Optional Vercel standard cron secret (usually same value)
CRON_SECRET=
# Max queued/running jobs processed per cron execution (recommended 1-5)
AI_JOBS_CRON_BATCH=2

# Trusted Proxies (for IP rate limiting behind load balancers)
# Comma-separated list of trusted proxy IPs
TRUSTED_PROXIES=

# GitHub App (optional — enables PR review automation and webhook-triggered scans)
# Create at https://github.com/settings/apps/new
GITHUB_APP_ID=
# Paste the entire PEM private key (include -----BEGIN/END RSA PRIVATE KEY----- lines)
GITHUB_APP_PRIVATE_KEY=
# The webhook secret you set when creating the app
GITHUB_WEBHOOK_SECRET=
# The URL users click to install your app on their org/repo
GITHUB_APP_INSTALL_URL=
