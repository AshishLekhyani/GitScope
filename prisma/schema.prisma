generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AiTier {
  free
  professional
  team
  enterprise
}

enum AiJobType {
  deepImpact
}

enum AiJobStatus {
  queued
  running
  completed
  failed
  canceled
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  password      String?   // Added for Credentials provider
  image         String?
  bio           String?
  githubHandle  String?
  githubApiKey  String?   // Personal GitHub token for higher rate limits
  aiTier        AiTier    @default(free) @map("ai_tier")
  aiTierUpdatedAt DateTime @default(now()) @map("ai_tier_updated_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  accounts      Account[]
  sessions      Session[]
  searchHistories SearchHistory[]
  notifications Notification[]
  aiUsageEvents AiUsageEvent[]
  aiAnalysisJobs AiAnalysisJob[]
  
  // Custom GitScope relations can be added here
  // e.g., Profile, Organizations, Projects

  @@map("users")
}

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String   // The search query or repo name
  type      String   // "repo" | "user"
  avatar    String?  // Optional avatar URL for better UX
  timestamp DateTime @default(now()) @map("timestamp")

  @@unique([userId, query])
  @@index([userId])
  @@map("search_histories")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("info") // info, warning, error, success
  isRead    Boolean  @default(false) @map("is_read")
  link      String?  // Optional link to navigate to
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("notifications")
}

model PendingSignup {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  hashedPassword String   @db.Text
  token          String   @unique
  expires        DateTime
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("pending_signups")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model AiUsageEvent {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature   String
  plan      AiTier
  units     Int      @default(1)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, feature, createdAt])
  @@index([createdAt])
  @@map("ai_usage_events")
}

model AiAnalysisJob {
  id          String      @id @default(cuid())
  userId      String      @map("user_id")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        AiJobType
  status      AiJobStatus @default(queued)
  plan        AiTier
  input       Json
  result      Json?
  error       String?
  attempts    Int         @default(0)
  startedAt   DateTime?   @map("started_at")
  completedAt DateTime?   @map("completed_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("ai_analysis_jobs")
}
// identifier prefixes:
//   "verify:{email}"  — email address verification (expires 24h)
//   "reset:{email}"   — password reset (expires 1h)
// Prisma schema v1 - User + Session
