generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AiTier {
  free
  professional
  developer
  team
  enterprise
}

enum AiJobType {
  deepImpact
  codeReview
  repoScan
}

enum ScheduleFrequency {
  daily
  weekly
  monthly
}

enum AiJobStatus {
  queued
  running
  completed
  failed
  canceled
}

enum SecurityEventSeverity {
  info
  warning
  error
  critical
}

model Account {
  id                 String  @id @default(cuid())
  userId             String  @map("user_id")
  type               String
  provider           String
  providerAccountId  String  @map("provider_account_id")
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  password      String?   // Added for Credentials provider
  image         String?
  bio           String?
  githubHandle  String?
  githubApiKey  String?   // Personal GitHub token for higher rate limits
  aiTier        AiTier    @default(free) @map("ai_tier")
  aiTierUpdatedAt DateTime @default(now()) @map("ai_tier_updated_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  // Integrations
  slackWebhookUrl      String?  @map("slack_webhook_url")   // Slack incoming webhook for alerts
  discordWebhookUrl    String?  @map("discord_webhook_url") // Discord incoming webhook for alerts
  weeklyDigestEnabled  Boolean  @default(false) @map("weekly_digest_enabled")
  weeklyDigestLastSent DateTime? @map("weekly_digest_last_sent")
  githubAppInstallId   String?  @map("github_app_install_id") // GitHub App installation ID

  // BYOK — Bring Your Own Key (keys are AES-256-GCM encrypted with ENCRYPTION_SECRET before storage)
  byokAnthropicKey  String?  @map("byok_anthropic_key") @db.Text
  byokOpenAIKey     String?  @map("byok_openai_key") @db.Text
  byokGeminiKey     String?  @map("byok_gemini_key") @db.Text

  accounts        Account[]
  sessions        Session[]
  searchHistories SearchHistory[]
  notifications   Notification[]
  aiUsageEvents   AiUsageEvent[]
  aiAnalysisJobs  AiAnalysisJob[]
  bookmarks       Bookmark[]
  codeReviewScans CodeReviewScan[]
  repoKnowledge   RepoKnowledge[]
  repoScanHistory RepoScanHistory[]
  scheduledScans  ScheduledScan[]
  customScanRules CustomScanRule[]
  actionItems     ActionItem[]
  ownedOrgs       Organization[]    @relation("OrgOwner")
  orgMemberships  OrgMember[]       @relation("OrgMemberships")
  webhookRules    WebhookRule[]
  apiKeys         ApiKey[]

  @@map("users")
}

model SearchHistory {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query     String   // The search query or repo name
  type      String   // "repo" | "user"
  avatar    String?  // Optional avatar URL for better UX
  timestamp DateTime @default(now()) @map("timestamp")

  @@unique([userId, query])
  @@index([userId])
  @@map("search_histories")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("info") // info, warning, error, success
  isRead    Boolean  @default(false) @map("is_read")
  link      String?  // Optional link to navigate to
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("notifications")
}

model PendingSignup {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  hashedPassword String   @db.Text
  token          String   @unique
  expires        DateTime
  createdAt      DateTime @default(now()) @map("created_at")

  @@map("pending_signups")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model AiUsageEvent {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  feature   String
  plan      AiTier
  units     Int      @default(1)
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, feature, createdAt])
  @@index([createdAt])
  @@map("ai_usage_events")
}

model AiAnalysisJob {
  id          String      @id @default(cuid())
  userId      String      @map("user_id")
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        AiJobType
  status      AiJobStatus @default(queued)
  plan        AiTier
  input       Json
  result      Json?
  error       String?
  attempts    Int         @default(0)
  startedAt   DateTime?   @map("started_at")
  completedAt DateTime?   @map("completed_at")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([userId, status, createdAt])
  @@map("ai_analysis_jobs")
}

model AuditLog {
  id        String               @id @default(cuid())
  eventType String               @map("event_type")
  userId    String?              @map("user_id")
  email     String?
  ip        String
  userAgent String?              @map("user_agent")
  metadata  Json?
  severity  SecurityEventSeverity
  success   Boolean              @default(true)
  timestamp DateTime             @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([severity])
  @@index([timestamp])
  @@index([ip])
  @@map("audit_logs")
}
model Bookmark {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  owner       String
  repo        String
  avatar      String   @default("")
  stars       Int      @default(0)
  description String   @default("")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([userId, owner, repo])
  @@index([userId])
  @@map("bookmarks")
}

model CodeReviewScan {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  repo        String
  prNumber    Int?     @map("pr_number")
  commitSha   String?  @map("commit_sha")
  scanMode    String   @default("quick") @map("scan_mode")
  analysisType String  @default("pr") @map("analysis_type")
  result      Json
  tokensUsed  Int      @default(0) @map("tokens_used")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId, repo])
  @@index([createdAt])
  @@map("code_review_scans")
}

// ── Codebase Memory System ─────────────────────────────────────────────────────
// Stores AI-generated knowledge about repositories, plan-gated by TTL.
// Free: ephemeral (1h), Professional: 7d, Team: 30d + org-shared, Enterprise: 90d + team patterns
model RepoKnowledge {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orgId         String?  @map("org_id")         // Shared across org for team/enterprise
  repo          String                           // "owner/repo"
  knowledgeType String   @map("knowledge_type") // "scan-result" | "team-patterns" | "architecture"
  summary       String   @db.Text               // AI-generated narrative summary
  patterns      Json     @default("[]")         // Detected architectural patterns
  insights      Json     @default("{}")         // Structured findings (security, quality, etc.)
  fileCount     Int      @default(0) @map("file_count")
  tokensUsed    Int      @default(0) @map("tokens_used")
  expiresAt     DateTime @map("expires_at")     // Plan-gated TTL
  lastUpdated   DateTime @default(now()) @map("last_updated") @updatedAt
  createdAt     DateTime @default(now()) @map("created_at")

  @@unique([userId, repo, knowledgeType])
  @@index([userId, repo])
  @@index([orgId, repo])
  @@index([expiresAt])
  @@map("repo_knowledge")
}

// ── Scan History ───────────────────────────────────────────────────────────────
// One row per completed repo scan. Used for health trend charts.
// Pro: 30d retention  |  Team: 90d  |  Enterprise: unlimited
model RepoScanHistory {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  repo             String
  scanMode         String   @default("quick") @map("scan_mode")
  healthScore      Int      @map("health_score")
  securityScore    Int      @map("security_score")
  qualityScore     Int      @map("quality_score")
  performanceScore Int      @default(0) @map("performance_score")
  criticalCount    Int      @default(0) @map("critical_count")
  highCount        Int      @default(0) @map("high_count")
  mediumCount      Int      @default(0) @map("medium_count")
  locEstimate      String?  @map("loc_estimate")
  filesScanned     Int      @default(0) @map("files_scanned")
  summary          String   @db.Text
  model            String?
  tokensUsed       Int      @default(0) @map("tokens_used")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([userId, repo, createdAt])
  @@index([userId, createdAt])
  @@map("repo_scan_history")
}

// ── Scheduled Scans ────────────────────────────────────────────────────────────
// Pro+ feature: run scans on a schedule and email alerts on score drops.
model ScheduledScan {
  id          String            @id @default(cuid())
  userId      String            @map("user_id")
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  repo        String
  scanMode    String            @default("quick") @map("scan_mode")
  schedule    ScheduleFrequency
  alertOnDrop Int?              @map("alert_on_drop") // send alert if score drops by ≥ this many points
  alertEmail  String?           @map("alert_email")   // where to send alerts
  lastRunAt   DateTime?         @map("last_run_at")
  lastScore   Int?              @map("last_score")
  nextRunAt   DateTime          @map("next_run_at")
  enabled     Boolean           @default(true)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@unique([userId, repo])
  @@index([nextRunAt, enabled])
  @@map("scheduled_scans")
}

// ── Custom Scan Rules ──────────────────────────────────────────────────────────
// Team+ feature: user-defined regex rules applied during static analysis.
model CustomScanRule {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.Text
  pattern     String   @db.Text  // JS-compatible regex pattern string (no delimiters)
  fileGlob    String?  @map("file_glob")  // optional file filter e.g. "**/*.ts"
  severity    String   @default("medium") // critical|high|medium|low
  category    String   @default("quality")
  suggestion  String   @db.Text
  enabled     Boolean  @default(true)
  hitCount    Int      @default(0) @map("hit_count") // incremented when rule fires
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("custom_scan_rules")
}

// ── Benchmark Stats ────────────────────────────────────────────────────────────
// Aggregated anonymous score statistics for benchmark comparisons ("your repo vs median").
// Populated by a background job that computes percentiles across all scan history rows.
model BenchmarkStat {
  id          String   @id @default(cuid())
  language    String   @default("all")     // "all" | "typescript" | "python" | etc.
  sizeClass   String   @default("all")     // "all" | "small" | "medium" | "large"
  metric      String                       // "healthScore" | "securityScore" | "qualityScore" | "performanceScore"
  p25         Float                        // 25th percentile
  p50         Float                        // median
  p75         Float                        // 75th percentile
  p90         Float                        // 90th percentile
  sampleCount Int      @map("sample_count")
  computedAt  DateTime @default(now()) @map("computed_at")

  @@unique([language, sizeClass, metric])
  @@index([metric])
  @@map("benchmark_stats")
}

// ── Action Items ───────────────────────────────────────────────────────────────
// Saved scan findings that the user wants to track and fix.
model ActionItem {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  repo        String
  title       String
  description String   @db.Text
  suggestion  String   @db.Text
  severity    String   @default("medium") // critical|high|medium|low|info
  category    String   @default("quality")
  file        String?
  status      String   @default("open")  // open|in_progress|done|dismissed
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId, status, createdAt])
  @@index([userId, repo])
  @@map("action_items")
}

// ── Public Repo Scan Cache ─────────────────────────────────────────────────────
// Shared cross-user cache for public repos. Before calling the LLM for a public
// repo scan, check here first. Populated after every successful LLM scan.
// TTL: 24h for quick scans, 48h for deep scans.
model PublicScanCache {
  id        String   @id @default(cuid())
  repo      String
  scanMode  String   @default("quick") @map("scan_mode")
  result    Json
  hitCount  Int      @default(0) @map("hit_count")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([repo, scanMode])
  @@index([expiresAt])
  @@map("public_scan_cache")
}

// ── Team / Workspace Seat Management ──────────────────────────────────────────
enum OrgRole {
  owner
  admin
  member
  viewer
}

model Organization {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  ownerId       String   @map("owner_id")
  owner         User     @relation("OrgOwner", fields: [ownerId], references: [id])
  plan          AiTier   @default(free)
  maxSeats      Int      @default(10)
  allowedDomain String?  @map("allowed_domain") // SSO: auto-join users from this email domain
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  members OrgMember[]
  invites OrgInvite[]

  @@map("organizations")
}

model OrgMember {
  id       String       @id @default(cuid())
  orgId    String       @map("org_id")
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userId   String       @map("user_id")
  user     User         @relation("OrgMemberships", fields: [userId], references: [id], onDelete: Cascade)
  role     OrgRole      @default(member)
  joinedAt DateTime     @default(now()) @map("joined_at")

  @@unique([orgId, userId])
  @@index([userId])
  @@map("org_members")
}

model OrgInvite {
  id        String       @id @default(cuid())
  orgId     String       @map("org_id")
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  email     String
  role      OrgRole      @default(member)
  token     String       @unique @default(cuid())
  expiresAt DateTime     @map("expires_at")
  createdAt DateTime     @default(now()) @map("created_at")

  @@unique([orgId, email])
  @@index([token])
  @@map("org_invites")
}

// ── Outbound Webhook Automation Rules ─────────────────────────────────────────
// Team+ feature: fire Slack/Discord/GitHub Issue/custom webhook when a metric crosses a threshold.
model WebhookRule {
  id               String    @id @default(cuid())
  userId           String    @map("user_id")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  enabled          Boolean   @default(true)
  // Trigger
  triggerMetric    String    @map("trigger_metric")    // "healthScore" | "securityScore" | "qualityScore" | "criticalCount"
  triggerOp        String    @map("trigger_op")        // "lt" | "gt" | "drop_by"
  triggerThreshold Float     @map("trigger_threshold")
  // Action
  actionType       String    @map("action_type")       // "slack" | "discord" | "github_issue" | "webhook"
  actionUrl        String?   @map("action_url")
  repoFilter       String?   @map("repo_filter")       // null = all repos; "owner/repo" = scoped
  // Stats
  lastTriggeredAt  DateTime? @map("last_triggered_at")
  triggerCount     Int       @default(0) @map("trigger_count")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("webhook_rules")
}

// ── Public API Keys ───────────────────────────────────────────────────────────
// Team+ feature: machine-readable API keys for the /api/v1/ public REST namespace.
// Keys are stored as SHA-256 hash only — the raw key is shown once at creation.
model ApiKey {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  keyHash    String    @unique @map("key_hash") // SHA-256 of the raw key
  prefix     String    // first 8 chars (sk_gs_XXXX) for display identification
  scopes     String[]  @default(["repos:read", "scans:read"])
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

// ── Global Announcement Banner ────────────────────────────────────────────────
// Admin-controlled banner shown to all logged-in users.
model Announcement {
  id        String   @id @default(cuid())
  message   String   @db.Text
  type      String   @default("info") // info | warning | error | success
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("announcements")
}

// identifier prefixes:
//   "verify:{email}"  — email address verification (expires 24h)
//   "reset:{email}"   — password reset (expires 1h)
// Prisma schema v5 - OrgRole, Organization, OrgMember, OrgInvite, WebhookRule, ApiKey, allowedDomain added
